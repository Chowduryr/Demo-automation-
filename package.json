{
  "name": "playwright-todomvc",
  "version": "1.0.0",
  "description": "Playwright automation suite for TodoMVC - Page Object Model + Allure Reporting",
  "scripts": {
    "test":              "npx playwright test",
    "test:ui":           "npx playwright test tests/ui/",
    "test:api":          "npx playwright test tests/api/",
    "test:chrome":       "npx playwright test --project=chromium",
    "test:firefox":      "npx playwright test --project=firefox",
    "test:safari":       "npx playwright test --project=webkit",
    "test:mobile":       "npx playwright test --project=mobile-chrome --project=mobile-safari",
    "test:headed":       "npx playwright test --headed",
    "test:debug":        "npx playwright test --debug",

    "allure:clean":      "rimraf allure-results allure-report",
    "allure:generate":   "allure generate allure-results --clean -o allure-report",
    "allure:open":       "allure open allure-report",
    "allure:serve":      "allure serve allure-results",

    "report:html":       "npx playwright show-report",
    "report:allure":     "npm run allure:generate && npm run allure:open",

    "test:full":         "npm run allure:clean && npx playwright test && npm run allure:generate"
  },
  "devDependencies": {
    "@playwright/test":  "^1.42.0",
    "allure-playwright": "^2.14.0",
    "allure-js-commons": "^2.14.0",
    "rimraf":            "^5.0.5"
  }
}
